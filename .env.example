# zGemma 서버 설정 (이 파일을 .env로 복사해서 사용하세요)
# Bun이 .env를 자동 로드하므로 dotenv는 필요 없습니다.

# gguf 모델 파일 경로 (상대 경로면 실행 디렉터리 기준)
MODEL_PATH=gemma-4-12b-it-Q4_K_M.gguf

# OpenAI 호환 응답에 노출할 모델 id
MODEL_ID=gemma-4

# 컨텍스트 크기. 16GB RAM 기준 4096 권장, 최대 8192까지 타협
CONTEXT_SIZE=4096

# 추론 스레드 수 (M1 성능 코어 수 기준 4)
THREADS=4

# 서버 포트 (Ollama 호환을 위해 11434)
PORT=11434
